# ===== ШАБЛОН .env =====
# Скопируйте этот файл в .env (cp .env.example .env), а затем впишите
# свои значения. Оригинальный файл .env я, естественно, в репозиторий не пушил, так как токен на бота
# это конфиденциальная информация, и он же использовался в рамках итоговой работы по Java (так что он в .gitignore).

# Токен от @BotFather (получается командой /newbot)
BOT_TOKEN=сюда_токен_от_BotFather

# Username бота без @ (нужен для ссылок «поделиться»)
BOT_USERNAME=сюда_username_бота_без_собачки

# Числовой ID вашего Telegram-аккаунта (узнаётся у @userinfobot).
# Используется для пересылки результатов и отзывов администратору.
ADMIN_CHAT_ID=сюда_ваш_числовой_id

# Контакты условного сотрудника зоопарка (как вариант, мои или Ваши)
ADMIN_USERNAME=ваш_telegram_username
ADMIN_EMAIL=ваш@email.ru
ADMIN_PHONE=+7 (999) 000-00-00
